{
	"name": "celema/verba",
	"description": "Gettext-style internationalization for PHP without the gettext extension",
	"type": "library",
	"license": "MIT",
	"authors": [
		{
			"name": "Ernst",
			"email": "ernst@celema.dev"
		}
	],
	"homepage": "https://celema.dev/verba",
	"keywords": [
		"celema",
		"internationalization",
		"i18n"
	],
	"autoload": {
		"psr-4": {
			"Celema\\Verba\\": "src/"
		},
		"files": [
			"src/functions.php"
		]
	},
	"autoload-dev": {
		"psr-4": {
			"Celema\\Verba\\Tests\\": "tests"
		}
	},
	"require": {
		"php": "^8.5",
		"celema/console": "^0.4"
	},
	"require-dev": {
		"celema/dev": "^5.0"
	},
	"scripts": {
		"test": [
			"./vendor/bin/phpunit --testdox --no-coverage --colors=always"
		],
		"types": "./vendor/bin/psalm --no-cache",
		"docs:format": "npx prettier@3.6.2 --write README.md CHANGELOG.md LICENSE.md .github/README.md \"docs/**/*.md\"",
		"docs:lint": "npx markdownlint-cli2@0.22.1 --config ./vendor/celema/dev/config/markdownlint.jsonc README.md CHANGELOG.md LICENSE.md .github/README.md \"docs/**/*.md\"",
		"lint": [
			"./vendor/bin/mago fmt --check",
			"./vendor/bin/mago lint"
		],
		"coverage:test": "./vendor/bin/phpunit --testdox --colors=always",
		"coverage:analyze": "./vendor/bin/coverlyzer .coverage/coverage.php",
		"coverage": [
			"composer coverage:test",
			"composer coverage:analyze"
		],
		"ci": [
			"composer lint",
			"composer coverage",
			"composer types",
			"composer docs:lint"
		]
	}
}
