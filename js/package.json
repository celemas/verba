{
	"name": "@celema/verba",
	"version": "0.3.0",
	"description": "JavaScript runtime for Celema Verba translation catalogs",
	"license": "MIT",
	"homepage": "https://celema.dev/verba",
	"repository": {
		"type": "git",
		"url": "git+https://codeberg.org/celema/verba.git",
		"directory": "js"
	},
	"keywords": [
		"celema",
		"internationalization",
		"i18n",
		"gettext"
	],
	"type": "module",
	"packageManager": "pnpm@11.5.0",
	"publishConfig": {
		"access": "public"
	},
	"exports": {
		".": {
			"types": "./dist/index.d.ts",
			"default": "./dist/index.js"
		}
	},
	"files": [
		"dist"
	],
	"sideEffects": false,
	"scripts": {
		"build": "tsc -p tsconfig.build.json",
		"check": "tsc && prettier --check .",
		"format": "prettier --write .",
		"prepack": "pnpm run build",
		"prepublishOnly": "pnpm run check && pnpm run test",
		"test": "vitest run"
	},
	"devDependencies": {
		"prettier": "^3.9.4",
		"typescript": "^7.0.2",
		"vitest": "^4.1.10"
	}
}
